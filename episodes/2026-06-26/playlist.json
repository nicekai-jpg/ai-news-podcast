        "lively": "chunk_003_lively.mp3"
      },
      "voices": {
        "professional": "host_b_professional",
        "lively": "host_b_lively"
      }
    },
    {
      "id": 4,
      "host": "A",
      "text": "你说到点子上了。前两年大家张口闭口都是千亿、万亿参数，现在风口确实在转。",
      "start": 22.948,
      "duration": 7.358,
