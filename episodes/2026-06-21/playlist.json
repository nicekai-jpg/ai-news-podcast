  "chunks": [
    {
      "id": 1,
      "host": "B",
      "text": "哈喽大家好，欢迎收听AI每日先锋，我是晓晓。",
      "start": 1.0,
      "duration": 5.399,
      "audios": {
        "professional": "chunk_001_professional.mp3",
