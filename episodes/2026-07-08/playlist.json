  "chunks": [
    {
      "id": 1,
      "host": "A",
      "text": "听众朋友们大家好，欢迎收听AI每日先锋，今天是2026年7月8日。我是苏晴。",
      "start": 1.0,
      "duration": 5.355,
      "audios": {
