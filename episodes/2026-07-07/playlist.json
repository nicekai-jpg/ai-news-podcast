        "lively": "chunk_048_lively.mp3"
      },
      "voices": {
        "professional": "host_b_professional",
        "lively": "host_b_lively"
      }
    },
    {
      "id": 49,
      "host": "A",
      "text": "我发现一个事儿哈——以前大家都是先开技术发布会，再开产品发布会。现在反过来，产品先出了，攒一波用户，再回去迭代技术。",
      "start": 447.955,
