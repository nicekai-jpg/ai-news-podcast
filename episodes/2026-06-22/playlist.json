      }
    },
    {
      "id": 2,
      "host": "A",
      "text": "大家好，我是博文。晓晓，今天就咱们俩聊啊？",
      "start": 9.199,
      "duration": 3.091,
      "audios": {
        "professional": "chunk_002_professional.mp3",
