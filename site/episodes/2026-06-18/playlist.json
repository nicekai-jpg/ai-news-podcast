{
  "episode_id": "2026-06-18",
  "chunks": [
    {
      "id": 1,
      "host": "B",
      "text": "听众朋友们大家好，欢迎收听AI每日先锋，今天是2026年6月18日，我是晓晓。",
      "start": 1.0,
      "duration": 7.043,
      "audios": {
        "v1": "chunk_001_v1.mp3",
        "v2": "chunk_001_v2.mp3"
      },
