# AI 每日先锋 环境变量模板
# 复制本文件为 .env 并填入真实值

# OpenAI 兼容 API（支持 DeepSeek、SiliconFlow、原生 OpenAI）
OPENAI_API_KEY="sk-xxx"

# Google Gemini
GEMINI_API_KEY="xxx"

# 本地 Ollama（无需真实 Key，可任意填写）
LLM_API_KEY="ollama"

# DashScope（阿里云，用于可选的 CosyVoice TTS）
DASHSCOPE_API_KEY="xxx"

# 代理设置（如需）
# HTTPS_PROXY="http://127.0.0.1:7890"

# 播客站点基础 URL（用于 RSS feed 中的链接）
# PODCAST_BASE_URL="https://yourname.github.io/ai-news-podcast"
